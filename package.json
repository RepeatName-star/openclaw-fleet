{
  "name": "openclaw-fleet",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build && node dist/index.js",
    "dev:ts": "node --enable-source-maps --loader ts-node/esm src/index.ts",
    "sidecar:dev": "pnpm build && node dist/sidecar/cli.js",
    "sidecar:dev:ts": "node --enable-source-maps --loader ts-node/esm src/sidecar/cli.ts",
    "sidecar:start": "node dist/sidecar/cli.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "pg": "^8.11.5",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "pg-mem": "^2.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
