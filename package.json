{
  "name": "openclaw-fleet",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build && node dist/index.js",
    "dev:ts": "node --enable-source-maps --loader ts-node/esm src/index.ts",
    "sidecar:dev": "pnpm build && node dist/sidecar/cli.js",
    "sidecar:dev:ts": "node --enable-source-maps --loader ts-node/esm src/sidecar/cli.ts",
    "sidecar:start": "node dist/sidecar/cli.js",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "ui:dev": "vite --config ui/vite.config.ts",
    "ui:build": "vite build --config ui/vite.config.ts"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "pg-mem": "^2.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.4.12",
    "vitest": "^1.6.0"
  }
}
